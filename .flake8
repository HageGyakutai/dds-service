[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude = .git,.venv,venv,__pycache__,migrations
per-file-ignores =
    config/settings/__init__.py:F401,F403,
    apps/references/models/__init__.py:F401,F403,
    apps/transactions/models/__init__.py:F401,F403,
    apps/references/views/__init__.py:F401,F403,
